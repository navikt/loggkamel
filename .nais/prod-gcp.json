{
  "ingresses": [
    "https://loggkamel.intern.nav.no"
  ],
  "db": {
    "poolsize": "2",
    "type": "POSTGRES_18",
    "tier": "db-custom-1-3840",
    "name": "loggkamel"
  },
  "db-flags": {
    "pgaudit": {
      "enabled": "off",
      "logtype": "ddl,role,write",
      "logparameter": "off"
    }
  },
  "buckets": [
    {
      "name": "loggkamel-prod"
    }
  ],
  "inbound": [
    {
      "name": "azure-token-generator",
      "namespace": "nais",
      "cluster": "prod-gcp"
    }
  ],
  "nais": {
    "cluster": {
      "plan" : "startup-4",
      "type": "prod"
    }
  },
  "mem": {
    "min": "1Gi",
    "max": "2Gi"
  },
  "cpu": {
    "min": "30m"
  },
  "replica": {
    "min": 4,
    "max": 4
  }
}