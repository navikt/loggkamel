{
  "ingresses": [
    "https://loggkamel.intern.dev.nav.no"
  ],
  "db": {
    "poolsize": "20",
    "type": "POSTGRES_18",
    "tier": "db-custom-1-3840",
    "name": "loggkamel"
  },
  "db-flags": {
    "pgaudit": {
      "enabled": "on",
      "logtype": "ddl,role,write",
      "logparameter": "on"
    }
  },
  "buckets": [
    {
      "name": "loggkamel-dev-postgresql-invalid-message"
    },
    {
      "name": "loggkamel-dev-postgresql-consumer"
    },
    {
      "name": "loggkamel-dev-logglines"
    },
    {
      "name": "loggkamel-dev-logglines-invalid-message"
    }
  ],
  "inbound": [
    {
      "name": "azure-token-generator",
      "namespace": "nais",
      "cluster": "dev-gcp"
    }
  ],
  "nais": {
    "cluster": {
      "plan" : "startup-4",
      "type": "dev"
    }
  },
  "mem": {
    "min": "1Gi",
    "max": "2Gi"
  },
  "cpu": {
    "min": "30m"
  },
  "replica": {
    "min": 2,
    "max": 2
  }
}